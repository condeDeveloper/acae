generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Papel {
  professor
  coordenador
}

enum StatusProfessor {
  ativo
  inativo
}

enum Turno {
  manha
  tarde
  integral
}

enum StatusTurma {
  ativa
  inativa
}

enum StatusAluno {
  ativo
  inativo
  excluido
}

enum TipoDocumento {
  portfolio_semanal
  portfolio_mensal
  relatorio_individual
  atividade_adaptada
  resumo_pedagogico
}

enum StatusDocumento {
  rascunho
  em_revisao
  finalizado
}

// ─────────────────────────────────────────────────────────────
// 1. PROFESSOR
// ─────────────────────────────────────────────────────────────

model Professor {
  id               String          @id @default(uuid()) @db.Uuid
  nome             String
  email            String          @unique
  papel            Papel           @default(professor)
  escola           String
  status           StatusProfessor @default(ativo)
  supabase_user_id String          @unique @db.Uuid

  turmas    Turma[]
  rascunhos RascunhoDocumento[]
  versoes   VersaoDocumento[]
  chamadas  Chamada[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("professores")
}

// ─────────────────────────────────────────────────────────────
// 2. TURMA
// ─────────────────────────────────────────────────────────────

model Turma {
  id         String      @id @default(uuid()) @db.Uuid
  nome       String
  ano_letivo Int
  turno      Turno
  escola     String
  status     StatusTurma @default(ativa)

  professor_id String    @db.Uuid
  professor    Professor @relation(fields: [professor_id], references: [id])

  alunos    Aluno[]
  grupos    Grupo[]
  contextos ContextoPedagogico[]
  registros RegistroAluno[]
  rascunhos RascunhoDocumento[]
  versoes   VersaoDocumento[]
  chamadas  Chamada[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([professor_id])
  @@map("turmas")
}

// ─────────────────────────────────────────────────────────────
// 2.5 AVATAR DE ALUNO
// ─────────────────────────────────────────────────────────────

model AvatarImagem {
  id      Int    @id
  nome    String
  arquivo String

  alunos Aluno[]

  @@map("avatar_imagens")
}

// ─────────────────────────────────────────────────────────────
// 3. ALUNO
// ─────────────────────────────────────────────────────────────

model Aluno {
  id                        String      @id @default(uuid()) @db.Uuid
  nome                      String
  data_nascimento           DateTime?   @db.Date
  necessidades_educacionais String?     @db.Text
  status                    StatusAluno @default(ativo)

  avatar_id Int?
  avatar    AvatarImagem? @relation(fields: [avatar_id], references: [id])

  turma_id String @db.Uuid
  turma    Turma  @relation(fields: [turma_id], references: [id])

  grupos     GrupoAluno[]
  registros  RegistroAluno[]
  rascunhos  RascunhoDocumento[]
  versoes    VersaoDocumento[]
  presencas  PresencaChamada[]
  vineland   AvaliacaoVineland[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([turma_id])
  @@map("alunos")
}

// ─────────────────────────────────────────────────────────────
// 4. GRUPO + TABELA DE JUNÇÃO
// ─────────────────────────────────────────────────────────────

model Grupo {
  id   String @id @default(uuid()) @db.Uuid
  nome String

  turma_id String @db.Uuid
  turma    Turma  @relation(fields: [turma_id], references: [id])

  alunos GrupoAluno[]

  created_at DateTime @default(now())

  @@map("grupos")
}

model GrupoAluno {
  grupo_id String @db.Uuid
  aluno_id String @db.Uuid

  grupo Grupo @relation(fields: [grupo_id], references: [id])
  aluno Aluno @relation(fields: [aluno_id], references: [id])

  @@id([grupo_id, aluno_id])
  @@map("grupos_alunos")
}

// ─────────────────────────────────────────────────────────────
// 5. COMPETÊNCIA BNCC
// ─────────────────────────────────────────────────────────────

model CompetenciaBNCC {
  id                String @id @default(uuid()) @db.Uuid
  codigo            String @unique
  descricao         String @db.Text
  area_conhecimento String
  nivel_educacional String

  created_at DateTime @default(now())

  @@map("competencias_bncc")
}

// ─────────────────────────────────────────────────────────────
// 6. CONTEXTO PEDAGÓGICO
// ─────────────────────────────────────────────────────────────

model ContextoPedagogico {
  id             String  @id @default(uuid()) @db.Uuid
  periodo        String
  metodologia    String  @db.Text
  objetivos      String  @db.Text
  dinamica_grupo String? @db.Text

  turma_id String @db.Uuid
  turma    Turma  @relation(fields: [turma_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([turma_id, periodo])
  @@map("contextos_pedagogicos")
}

// ─────────────────────────────────────────────────────────────
// 7. REGISTRO DO ALUNO (por período)
// ─────────────────────────────────────────────────────────────

model RegistroAluno {
  id          String   @id @default(uuid()) @db.Uuid
  periodo     String
  objetivos   String   @db.Text
  atividades  String   @db.Text
  mediacoes   String?  @db.Text
  ocorrencias String?  @db.Text
  bncc_refs   String[]
  // CHECK: cardinality(bncc_refs) >= 1 via migration SQL

  aluno_id String @db.Uuid
  aluno    Aluno  @relation(fields: [aluno_id], references: [id])

  turma_id String @db.Uuid
  turma    Turma  @relation(fields: [turma_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([aluno_id, periodo])
  @@index([turma_id, periodo])
  @@map("registros_aluno")
}

// ─────────────────────────────────────────────────────────────
// 8. RASCUNHO DE DOCUMENTO
// ─────────────────────────────────────────────────────────────

model RascunhoDocumento {
  id                 String          @id @default(uuid()) @db.Uuid
  tipo               TipoDocumento
  status             StatusDocumento @default(rascunho)
  conteudo_gerado    String          @db.Text
  conteudo_editado   String?         @db.Text
  conteudo_final     String?         @db.Text
  periodo            String
  bncc_refs          String[]
  // CHECK: cardinality(bncc_refs) >= 1 via migration SQL
  prompt_hash        String
  duracao_geracao_ms Int?
  finalizado_em      DateTime?

  professor_id String    @db.Uuid
  professor    Professor @relation(fields: [professor_id], references: [id])

  aluno_id String? @db.Uuid
  aluno    Aluno?  @relation(fields: [aluno_id], references: [id])

  turma_id String @db.Uuid
  turma    Turma  @relation(fields: [turma_id], references: [id])

  versoes VersaoDocumento[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([professor_id, status])
  @@index([aluno_id, periodo])
  @@map("rascunhos_documento")
}

// ─────────────────────────────────────────────────────────────
// 9. VERSÃO DE DOCUMENTO — INSERT-ONLY
// Trigger impede UPDATE e DELETE (ver migration SQL)
// ─────────────────────────────────────────────────────────────

model VersaoDocumento {
  id            String   @id @default(uuid()) @db.Uuid
  numero_versao Int
  conteudo      String   @db.Text
  periodo       String
  bncc_refs     String[]
  finalizado_em DateTime

  rascunho_id String            @db.Uuid
  rascunho    RascunhoDocumento @relation(fields: [rascunho_id], references: [id])

  professor_id String    @db.Uuid
  professor    Professor @relation(fields: [professor_id], references: [id])

  aluno_id String? @db.Uuid
  aluno    Aluno?  @relation(fields: [aluno_id], references: [id])

  turma_id String @db.Uuid
  turma    Turma  @relation(fields: [turma_id], references: [id])

  created_at DateTime @default(now())

  @@unique([rascunho_id, numero_versao])
  @@index([professor_id])
  @@map("versoes_documento")
}

// ─────────────────────────────────────────────────────────────
// 10. ATIVIDADE BNCC — banco de atividades pedagógicas
// ─────────────────────────────────────────────────────────────

model AtividadeBNCC {
  id                String   @id @default(uuid()) @db.Uuid
  titulo            String
  descricao         String   @db.Text
  como_fazer        String   @db.Text
  materiais         String?  @db.Text
  area_conhecimento String
  nivel_educacional String
  bncc_refs         String[]
  dificuldade       String   // basica | intermediaria | avancada

  created_at DateTime @default(now())

  @@index([area_conhecimento])
  @@index([nivel_educacional])
  @@map("atividades_bncc")
}

// ─────────────────────────────────────────────────────────────
// 11. CONTROLE DE COTAS DE IA
// ─────────────────────────────────────────────────────────────

model ControleCotas {
  id                   String   @id @default(uuid()) @db.Uuid
  data                 DateTime @unique @db.Date
  contagem_requisicoes Int      @default(0)
  ultima_requisicao_em DateTime

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("controle_cotas")
}

// ─────────────────────────────────────────────────────────────
// 12. CHAMADA (frequência diária por turma)
// ─────────────────────────────────────────────────────────────

model Chamada {
  id   String   @id @default(uuid()) @db.Uuid
  data DateTime @db.Date

  turma_id String @db.Uuid
  turma    Turma  @relation(fields: [turma_id], references: [id])

  professor_id String    @db.Uuid
  professor    Professor @relation(fields: [professor_id], references: [id])

  presencas PresencaChamada[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([turma_id, data])
  @@index([professor_id])
  @@map("chamadas")
}

model PresencaChamada {
  id      String  @id @default(uuid()) @db.Uuid
  presente Boolean @default(false)

  chamada_id String  @db.Uuid
  chamada    Chamada @relation(fields: [chamada_id], references: [id], onDelete: Cascade)

  aluno_id String @db.Uuid
  aluno    Aluno  @relation(fields: [aluno_id], references: [id])

  @@unique([chamada_id, aluno_id])
  @@index([aluno_id])
  @@map("presencas_chamada")
}

// ─────────────────────────────────────────────────────────────
// 13. AVALIAÇÃO VINELAND-3
// ─────────────────────────────────────────────────────────────

model AvaliacaoVineland {
  id         String   @id @default(uuid()) @db.Uuid
  avaliador  String
  data_teste DateTime @db.Date

  // Comunicação
  com_bruta    Int
  com_padrao   Int    // pontuação padrão (CCA do domínio)
  com_nivel    String // "Baixo", "Moderado", etc.
  com_ic       String? // "51-61"
  com_percentil String? // "<1", "75", etc.

  // Atividades de Vida Diária
  avd_bruta    Int
  avd_padrao   Int
  avd_nivel    String
  avd_ic       String?
  avd_percentil String?

  // Socialização
  soc_bruta    Int
  soc_padrao   Int
  soc_nivel    String?
  soc_ic       String?
  soc_percentil String?

  // Composto
  soma_padroes  Int     // COM+AVD+SOC padrões
  cca_composto  Int     // Composto de Comportamento Adaptativo
  cca_ic        String? // "66-74"
  cca_percentil String? // "2"

  aluno_id String @db.Uuid
  aluno    Aluno  @relation(fields: [aluno_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([aluno_id])
  @@map("avaliacoes_vineland")
}
